# El SDK descubre la autenticacion del CLI de Claude Code automaticamente,
# asi que normalmente NO necesitas poner una API key aqui.
# Solo si quieres forzar el uso de la API de Anthropic directamente:
# ANTHROPIC_API_KEY=sk-ant-...

# Modelo del orquestador (ID completo). Subagentes usan nombres cortos en el codigo.
ORCHESTRATOR_MODEL=claude-opus-4-8

# Host/puerto del servidor web
HOST=127.0.0.1
PORT=8000

# --- WhatsApp via Twilio (opcional) ---
# Si dejas esto vacio, el sistema funciona igual pero NO envia WhatsApp.
# 1) Crea cuenta gratis en twilio.com
# 2) Messaging -> Try it out -> Send a WhatsApp message (activa el sandbox)
# 3) Desde tu WhatsApp envia "join <codigo>" al numero del sandbox
# 4) Copia tus credenciales aqui:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Tu numero en formato E.164 (con prefijo de pais). Ej. Espana: +34
WHATSAPP_TO=whatsapp:+34600000000

# --- Voz de Jarvis ---
# Indice del microfono (ver: python voz/jarvis_voz.py --check). -1 = el del sistema.
# MIC_INDEX=0
# Ganancia software para micros flojos (1 = sin cambio).
# JARVIS_GAIN=3
